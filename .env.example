# Required
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional
CLOUDFLARE_LIST_ITEM_LIMIT=300000   # max domains to block (Cloudflare free tier: 300k)
DRY_RUN=0                           # set to 1 to preview changes without touching Cloudflare
BLOCK_PAGE_ENABLED=0                # set to 1 to show Cloudflare block page instead of NXDOMAIN

# Custom filter lists (one URL per line, leave blank to use defaults)
# BLOCKLIST_URLS=
# ALLOWLIST_URLS=
